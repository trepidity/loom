import { AppTheme } from "theme.slint";
import { StatusBar } from "status-bar.slint";
import { TabBar, TabInfo } from "tab-bar.slint";
import { TreeView, TreeNode } from "tree-view.slint";
import { DetailPanel, AttributeRow } from "detail-panel.slint";
import { ProfileDialog } from "profile-dialog.slint";
import { VaultDialog } from "vault-dialog.slint";
import { CredentialDialog } from "credential-dialog.slint";
import { ExportDialog } from "export-dialog.slint";
import { SearchDialog, SearchResult } from "search-dialog.slint";
import { ThemeSelector } from "theme-selector.slint";

export { AppTheme }

export component MainWindow inherits Window {
    title: "Loom Browser";
    preferred-width: 1200px;
    preferred-height: 800px;
    background: AppTheme.bg-primary;

    // Status
    in-out property <string> status-message: "Ready";
    in-out property <bool> status-is-error: false;

    // Tabs
    in-out property <[TabInfo]> tabs: [];
    in-out property <int> active-tab: -1;
    callback tab-clicked(int);
    callback close-tab(int);

    // Tree
    in-out property <[TreeNode]> tree-model: [];
    in-out property <int> tree-selected-index: -1;
    callback tree-toggle-expand(int);
    callback tree-node-selected(int);

    // Profiles
    callback connect-profile(int);

    // Profile dialog
    in-out property <bool> profile-dialog-visible: false;
    in-out property <string> profile-dialog-title: "New Profile";
    in-out property <string> profile-dialog-name: "";
    in-out property <string> profile-dialog-host: "";
    in-out property <string> profile-dialog-port: "389";
    in-out property <string> profile-dialog-tls-mode: "auto";
    in-out property <string> profile-dialog-bind-dn: "";
    in-out property <string> profile-dialog-base-dn: "";
    in-out property <string> profile-dialog-credential-method: "prompt";
    in-out property <string> profile-dialog-folder: "";
    callback new-profile-requested();
    callback save-profile(string, string, int, string, string, string, string, string);

    // Detail
    in-out property <[AttributeRow]> attributes: [];
    in-out property <string> entry-dn: "";

    // Vault dialog
    in-out property <bool> vault-dialog-visible: false;
    in-out property <string> vault-error: "";
    callback vault-unlock(string);
    callback vault-skip();

    // Credential dialog
    in-out property <bool> credential-dialog-visible: false;
    in-out property <string> credential-profile-name: "";
    in-out property <string> credential-bind-dn: "";
    callback credential-connect(string);
    callback credential-cancel();

    // Search dialog
    in-out property <bool> search-dialog-visible: false;
    in-out property <string> search-base-dn: "";
    in-out property <string> search-filter: "(objectClass=*)";
    in-out property <int> search-scope-index: 0;
    in-out property <[SearchResult]> search-results: [];
    callback show-search-dialog();
    callback search-execute(string, string, int);
    callback search-result-selected(int);
    callback search-cancel();

    // Theme selector
    in-out property <bool> theme-selector-visible: false;
    in-out property <string> current-theme: "dark";
    callback show-theme-selector();
    callback change-theme(string);

    // Menu bar
    callback menu-quit();
    callback show-about();

    // Export dialog
    in-out property <bool> export-dialog-visible: false;
    in-out property <string> export-base-dn: "";
    callback show-export-dialog();
    callback export-execute(string, string, int);
    callback export-cancel();

    MenuBar {
        Menu {
            title: "Profiles";
            MenuItem {
                title: "New Profile...";
                activated => { root.new-profile-requested(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "Quit";
                activated => { root.menu-quit(); }
            }
        }
        Menu {
            title: "Edit";
            MenuItem {
                title: "Search (Ctrl+F)";
                activated => { root.show-search-dialog(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "Export...";
                activated => { root.show-export-dialog(); }
            }
        }
        Menu {
            title: "View";
            MenuItem {
                title: "Theme...";
                activated => { root.show-theme-selector(); }
            }
        }
        Menu {
            title: "Help";
            MenuItem {
                title: "About";
                activated => { root.show-about(); }
            }
        }
    }

    VerticalLayout {
        TabBar {
            height: 36px;
            tabs: root.tabs;
            active-tab: root.active-tab;
            tab-clicked(index) => { root.tab-clicked(index); }
            close-tab(index) => { root.close-tab(index); }
        }

        // Main content - empty state
        if root.tabs.length == 0 : Rectangle {
            vertical-stretch: 1;
            background: AppTheme.bg-primary;

            Text {
                text: "No connections. Use Profiles > New Profile to get started.";
                color: AppTheme.fg-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 14px;
            }
        }

        // Main content - tree + detail split
        if root.tabs.length > 0 : HorizontalLayout {
            vertical-stretch: 1;

            TreeView {
                model: root.tree-model;
                selected-index: root.tree-selected-index;
                horizontal-stretch: 1;
                toggle-expand(index) => { root.tree-toggle-expand(index); }
                node-selected(index) => { root.tree-node-selected(index); }
            }

            // Divider
            Rectangle {
                width: 1px;
                background: AppTheme.border;
            }

            DetailPanel {
                attributes: root.attributes;
                entry-dn: root.entry-dn;
                horizontal-stretch: 2;
            }
        }

        StatusBar {
            message: root.status-message;
            is-error: root.status-is-error;
        }
    }

    // Profile dialog overlay (drawn on top of everything)
    ProfileDialog {
        show <=> root.profile-dialog-visible;
        dialog-title <=> root.profile-dialog-title;
        profile-name <=> root.profile-dialog-name;
        host <=> root.profile-dialog-host;
        port <=> root.profile-dialog-port;
        tls-mode <=> root.profile-dialog-tls-mode;
        bind-dn <=> root.profile-dialog-bind-dn;
        base-dn <=> root.profile-dialog-base-dn;
        credential-method <=> root.profile-dialog-credential-method;
        folder <=> root.profile-dialog-folder;
        width: root.width;
        height: root.height;

        save-clicked => {
            root.save-profile(
                root.profile-dialog-name,
                root.profile-dialog-host,
                root.profile-dialog-port.to-float(),
                root.profile-dialog-tls-mode,
                root.profile-dialog-bind-dn,
                root.profile-dialog-base-dn,
                root.profile-dialog-credential-method,
                root.profile-dialog-folder,
            );
        }

        cancel-clicked => {
            root.profile-dialog-visible = false;
        }
    }

    // Vault dialog overlay (highest z-order, drawn on top of everything)
    VaultDialog {
        show <=> root.vault-dialog-visible;
        error-text <=> root.vault-error;
        width: root.width;
        height: root.height;

        unlock-clicked(password) => {
            root.vault-unlock(password);
        }

        skip-clicked => {
            root.vault-skip();
        }
    }

    // Credential dialog overlay
    CredentialDialog {
        show <=> root.credential-dialog-visible;
        profile-name <=> root.credential-profile-name;
        bind-dn <=> root.credential-bind-dn;
        width: root.width;
        height: root.height;

        connect-clicked(password) => {
            root.credential-connect(password);
        }

        cancel-clicked => {
            root.credential-dialog-visible = false;
            root.credential-cancel();
        }
    }

    // Export dialog overlay
    ExportDialog {
        show <=> root.export-dialog-visible;
        base-dn <=> root.export-base-dn;
        width: root.width;
        height: root.height;

        export-clicked(base-dn, file-path, format-index) => {
            root.export-execute(base-dn, file-path, format-index);
        }

        cancel-clicked => {
            root.export-dialog-visible = false;
            root.export-cancel();
        }
    }

    // Search dialog overlay
    SearchDialog {
        show <=> root.search-dialog-visible;
        base-dn <=> root.search-base-dn;
        filter <=> root.search-filter;
        scope-index <=> root.search-scope-index;
        results <=> root.search-results;
        width: root.width;
        height: root.height;

        search-clicked(base-dn, filter, scope-index) => {
            root.search-execute(base-dn, filter, scope-index);
        }

        result-selected(index) => {
            root.search-result-selected(index);
        }

        cancel-clicked => {
            root.search-dialog-visible = false;
            root.search-cancel();
        }
    }

    // Theme selector overlay
    ThemeSelector {
        show <=> root.theme-selector-visible;
        active-theme <=> root.current-theme;
        width: root.width;
        height: root.height;

        theme-selected(theme-name) => {
            root.change-theme(theme-name);
        }
    }
}
