import { AppTheme } from "theme.slint";
import { ListView } from "std-widgets.slint";

export struct ConnectProfile {
    name: string,
    host: string,
    index: int,
}

export component ConnectDialog inherits Rectangle {
    in-out property <bool> show: false;
    in property <[ConnectProfile]> profiles: [];
    callback profile-selected(int);
    callback cancel-clicked();

    visible: root.show;
    width: 100%;
    height: 100%;

    // Dark backdrop
    Rectangle {
        width: 100%;
        height: 100%;
        background: #00000088;

        TouchArea {
            clicked => { root.cancel-clicked(); }
        }
    }

    // Dialog card
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 400px;
        height: 360px;
        background: AppTheme.bg-secondary;
        border-radius: AppTheme.border-radius;
        border-width: 1px;
        border-color: AppTheme.border;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text: "Connect to Profile";
                color: AppTheme.fg-primary;
                font-size: 16px;
                font-weight: 600;
            }

            if root.profiles.length == 0: Text {
                text: "No saved profiles. Create one with Profiles > New Profile.";
                color: AppTheme.fg-muted;
                font-size: 13px;
                wrap: word-wrap;
            }

            ListView {
                vertical-stretch: 1;

                for profile[idx] in root.profiles: Rectangle {
                    height: 44px;
                    border-radius: AppTheme.border-radius;
                    background: row-touch.has-hover ? AppTheme.bg-hover : transparent;

                    row-touch := TouchArea {
                        clicked => { root.profile-selected(profile.index); }
                    }

                    VerticalLayout {
                        padding-left: 12px;
                        padding-top: 6px;
                        spacing: 2px;

                        Text {
                            text: profile.name;
                            color: AppTheme.fg-primary;
                            font-size: 14px;
                        }
                        Text {
                            text: profile.host;
                            color: AppTheme.fg-muted;
                            font-size: 12px;
                            font-family: "monospace";
                        }
                    }
                }
            }

            // Cancel button
            Rectangle {
                height: 32px;
                border-radius: AppTheme.border-radius;
                background: cancel-touch.has-hover ? AppTheme.bg-hover : AppTheme.bg-tertiary;

                cancel-touch := TouchArea {
                    clicked => { root.cancel-clicked(); }
                }

                Text {
                    text: "Cancel";
                    color: AppTheme.fg-secondary;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
