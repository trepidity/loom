import { AppTheme } from "theme.slint";
import { LineEdit } from "std-widgets.slint";

export component CredentialDialog inherits Rectangle {
    in-out property <bool> show: false;
    in-out property <string> profile-name: "";
    in-out property <string> bind-dn: "";
    in-out property <string> password: "";

    callback connect-clicked(string);
    callback cancel-clicked();

    // Full-screen overlay
    width: 100%;
    height: 100%;
    background: root.show ? #00000088 : transparent;

    if root.show : TouchArea {
        clicked => { root.cancel-clicked(); }
    }

    if root.show : Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 400px;
        height: 220px;
        background: AppTheme.bg-secondary;
        border-radius: AppTheme.border-radius;
        border-width: 1px;
        border-color: AppTheme.border;

        // Block clicks from reaching the overlay TouchArea
        TouchArea {}

        VerticalLayout {
            padding: AppTheme.padding;
            spacing: AppTheme.spacing;

            // Title
            Text {
                text: "Enter Password";
                color: AppTheme.fg-primary;
                font-size: 16px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            // Subtitle
            Text {
                text: root.profile-name + " — " + root.bind-dn;
                color: AppTheme.fg-secondary;
                font-size: 12px;
                horizontal-alignment: center;
                overflow: elide;
            }

            // Password input
            password-input := LineEdit {
                placeholder-text: "Password";
                input-type: InputType.password;
                text <=> root.password;
                accepted => {
                    root.connect-clicked(root.password);
                }
            }

            // Buttons
            HorizontalLayout {
                spacing: AppTheme.spacing;
                alignment: end;

                // Cancel button
                Rectangle {
                    width: 80px;
                    height: 32px;
                    background: cancel-ta.has-hover ? AppTheme.bg-hover : AppTheme.bg-tertiary;
                    border-radius: AppTheme.border-radius;
                    border-width: 1px;
                    border-color: AppTheme.border;

                    cancel-ta := TouchArea {
                        clicked => { root.cancel-clicked(); }
                    }

                    Text {
                        text: "Cancel";
                        color: AppTheme.fg-secondary;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Connect button
                Rectangle {
                    width: 80px;
                    height: 32px;
                    background: connect-ta.has-hover ? AppTheme.accent-hover : AppTheme.accent;
                    border-radius: AppTheme.border-radius;

                    connect-ta := TouchArea {
                        clicked => { root.connect-clicked(root.password); }
                    }

                    Text {
                        text: "Connect";
                        color: #ffffff;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
